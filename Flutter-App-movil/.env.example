# Configuración de la API Backend (Plantilla)
# ===================================
# Copia este archivo como .env y ajusta los valores

# IP del servidor backend (tu PC donde corre NestJS)
# Ejemplos según entorno:
# - Android Emulator: API_HOST=10.0.2.2
# - iOS Simulator: API_HOST=localhost  
# - Dispositivo físico: API_HOST=192.168.1.100 (tu IP local)
#
# Para encontrar tu IP en Windows, ejecuta: ipconfig
# Busca "IPv4" en tu conexión WiFi/Ethernet
API_HOST= 10.250.78.116

# Puerto del backend (normalmente 3000)
API_PORT=3000
